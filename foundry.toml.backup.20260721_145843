[profile.default]
optimizer = true
optimizer_runs = 200
ignored_error_codes = [2072, 3860, 5574]
src = "src"
out = "out"
libs = ["lib"]
test = "test"
script = "script"

# Payagan ang Foundry na mag-load ng environment variables mula sa .env
ffi = true

[profile.default.lint]
ignore = [
    "unaliased-plain-import",
    "asm-keccak256",
    "screaming-snake-case-const",
    "unsafe-cheatcode"
]
