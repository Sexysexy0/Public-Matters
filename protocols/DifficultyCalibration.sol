pragma solidity ^0.8.20;

contract DifficultyCalibration {
    // [Goal: Re-tune boss AI and damage scaling to restore the 'Hard Mode' experience]
    function restoreHardMode() external pure returns (string memory) {
        return "CALIBRATED: Boss aggression restored. Blinding spam combo nerfed. Real challenge active.";
    }
}
